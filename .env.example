# Copy to .env and adjust (never commit .env):
#   cp .env.example .env

# --- Airflow process user (files owned by this UID on the host)
AIRFLOW_UID=50000

# --- PostgreSQL (shared by Airflow, grammys_db, data_warehouse, dashboard)
# Use strong passwords outside local development.
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow
POSTGRES_PORT=5432

# --- Airflow encryption key (required)
# Example below is for local Docker only. For shared or production hosts, generate a new key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=

# --- Airflow web UI (first-time user created by airflow-init)
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_WEBSERVER_PORT=8080

# --- Google Drive upload (optional; paths are inside the container)
GOOGLE_CREDENTIALS_PATH=/opt/airflow/credentials/oauth_credentials.json
GOOGLE_DRIVE_FOLDER_ID=

# --- Dashboard
DASHBOARD_PORT=8501
