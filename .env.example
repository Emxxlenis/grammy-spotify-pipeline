# Copy this file to .env and fill in your values
# cp .env.example .env

# Required: UID of the user running Airflow inside Docker
AIRFLOW_UID=50000

# Optional: Google Drive upload
# Path to credentials inside the container (do not change)
GOOGLE_CREDENTIALS_PATH=/opt/airflow/credentials/service_account.json
# Folder ID from the Drive URL: drive.google.com/drive/folders/<FOLDER_ID>
GOOGLE_DRIVE_FOLDER_ID=
